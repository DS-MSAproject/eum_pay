flowchart LR
    subgraph ORD["orderserver — OrderState 전이"]
        direction TB
        CO["ORDER_CHECKED_OUT"]
        OS_RESOK["INVENTORY_RESERVED"]
        OS_RESFAIL["INVENTORY_RESERVATION_FAILED ❌"]
        OS_PAYOK["PAYMENT_COMPLETED"]
        OS_PAYFAIL["PAYMENT_FAILED ❌"]
        OS_DONE["ORDER_COMPLETED ✅"]
        OS_DEDFAIL["INVENTORY_DEDUCTION_FAILED ❌"]
        OS_RELED["INVENTORY_RELEASED\n(보상 완료)"]
        OS_RELFAIL["INVENTORY_RELEASE_FAILED ❌"]
    end

    subgraph INV["inventoryserver"]
        IR["InventoryReserved 발행"]
        IRF["InventoryReservationFailed 발행"]
        PR["PaymentRequested 발행"]
        ID["InventoryDeducted 발행"]
        IDF["InventoryDeductionFailed 발행"]
        IREL["InventoryReleased 발행"]
        IRELF["InventoryReleaseFailed 발행"]
    end

    subgraph PAY["paymentserver"]
        PAY_READY["Payment(READY) 생성"]
        PAY_CONF["결제 승인 ✅\nPaymentCompleted 발행"]
        PAY_FAIL["결제 실패 ❌\nPaymentFailed 발행"]
        PAY_CAN["결제 취소\nPaymentCancelled 발행"]
    end

    CO -->|OrderCheckedOut| IR
    CO -->|OrderCheckedOut| IRF

    IR -->|InventoryReserved| OS_RESOK
    IRF -->|InventoryReservationFailed| OS_RESFAIL

    IR -->|PaymentRequested| PAY_READY
    PAY_READY -->|"프론트 confirm 호출"| PAY_CONF
    PAY_READY -.->|"타임아웃 / Toss 오류"| PAY_FAIL

    PAY_CONF -->|PaymentCompleted| OS_PAYOK
    PAY_CONF -->|PaymentCompleted| ID
    ID -->|InventoryDeducted| OS_DONE
    IDF -->|InventoryDeductionFailed| OS_DEDFAIL

    PAY_FAIL -->|PaymentFailed| OS_PAYFAIL
    PAY_FAIL -->|PaymentFailed| IREL

    IREL -->|InventoryReleased| OS_RELED
    IRELF -->|InventoryReleaseFailed| OS_RELFAIL

    PAY_CAN -.->|"PaymentCancelled\n(외부 취소 경로)"| IREL

    style CO fill:#4A90D9,color:#fff
    style PAY_CONF fill:#27AE60,color:#fff
    style OS_DONE fill:#27AE60,color:#fff
    style OS_RESFAIL fill:#E74C3C,color:#fff
    style OS_PAYFAIL fill:#E74C3C,color:#fff
    style OS_DEDFAIL fill:#E74C3C,color:#fff
    style OS_RELFAIL fill:#E74C3C,color:#fff
    style OS_RELED fill:#F39C12,color:#fff
    style PAY_FAIL fill:#E74C3C,color:#fff
    style IRF fill:#E74C3C,color:#fff
